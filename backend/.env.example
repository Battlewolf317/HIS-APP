# =====================================================================
# Backend env — SALIN ke .env (lokal) atau set di dashboard Railway/Render.
# =====================================================================

# Koneksi Postgres terkelola (Neon/Railway/Render). WAJIB di production.
# Contoh Neon: postgresql://user:pass@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Mode production (mengaktifkan validasi JWT_SECRET kuat)
NODE_ENV=production

# Rahasia JWT — WAJIB min 16 karakter di production. Generate acak.
JWT_SECRET=ganti_dengan_string_acak_panjang_min16

# Masa berlaku token (opsional)
JWT_EXPIRES=8h

# Origin frontend yang diizinkan (CORS). Pisah koma. Isi URL Vercel kamu.
CORS_ORIGINS=https://his-app-anda.vercel.app

# Port (Railway/Render mengisi otomatis; default 3001)
# PORT=3001
